# Optional: override default stream URL (defaults to /stream/playlist.m3u8 via proxy)
# VITE_STREAM_URL=http://localhost:3001/stream/playlist.m3u8

# Optional: opt-in to HTTP/2 direct-backend mode for the multi-replay
# prefetch. When unset, the frontend uses relative URLs that go through
# the Vite proxy (works everywhere, including SSH port-forwarded dev,
# but capped at HTTP/1.1's 6 connections per origin).
#
# When set to an absolute URL, segment fetches go directly to the backend
# over HTTP/2 and multiplex on a single TLS connection (~135 parallel .ts
# fetches). The cert at that URL must be accepted in the browser, and
# the port must be reachable (forward it if running over SSH).
#
# VITE_API_BASE=https://localhost:3014
# VITE_API_BASE=https://192.168.0.10:3014
